# ===============================
# VOID ARENA / ABYSS TOURMENT GAME
# Configuração local
# ===============================

PORT=3002
SESSION_SECRET=troque-por-uma-chave-grande-e-aleatoria

# Bot Discord
DISCORD_TOKEN=COLE_SEU_TOKEN_NOVO_AQUI
CLIENT_ID=COLE_SEU_APPLICATION_ID_AQUI

# Login Discord
DISCORD_CLIENT_ID=COLE_SEU_APPLICATION_ID_AQUI
DISCORD_CLIENT_SECRET=COLE_SEU_CLIENT_SECRET_NOVO_AQUI
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback

# Administrador do painel (opcional)
ADMIN_DISCORD_IDS=
ADMIN_EMAILS=
ADMIN_USER_IDS=

# Split Site/Bot
# Porta da API interna do bot usada pelo site.
BOT_API_PORT=3002
# Use o mesmo token também no ZIP do site se quiser proteger a ponte interna.
BOT_API_KEY=
# Banco central do BOT. No Render, configure DATA_DIR=/var/data se usar Disk persistente.
DATA_DIR=./data

# Opção 2: o BOT é o dono do banco JSON e expõe API interna protegida para o SITE.
# No Render, o bot usa process.env.PORT automaticamente; local pode usar BOT_API_PORT=3002.
